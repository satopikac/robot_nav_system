{
  "profile": "turtlebot3_sim",

  "runtime": {
    "mode": "ros_multi",
    "use_ros": true,
    "auto_explore_on_startup": true,
    "resume_explore_after_task": true
  },

  "robots": {
    "names": ["tb3_0", "tb3_1", "tb3_2"],
    "global_frame": "map",
    "base_frame_suffix": "base_footprint",
    "goal_timeout": 300.0,
    "server_timeout": 10.0,
    "default_positions": {
      "tb3_0": [-7.0, -1.0],
      "tb3_1": [7.0, -1.0],
      "tb3_2": [0.5, 3.0]
    }
  },

  "ros": {
    "move_base_action": "move_base",
    "frame_id": "map",
    "base_frame": "base_footprint"
  },

  "dmros": {
    "enabled": true,
    "output_dir": "output/semantic",
    "ros_stream_config": "config/dmros/turtlebot3_sim.yaml",
    "poll_interval": 3.0,
    "use_llm_for_metadata": true
  },

  "exploration": {
    "enabled": true,
    "launch_file": "exploration/multi_explore.launch",
    "planner_frequency": 0.33,
    "min_frontier_size": 0.75,
    "progress_timeout": 30.0
  },

  "llm": {
    "base_url": "https://api.deepseek.com",
    "api_key": "",
    "model": "deepseek-chat",
    "temperature": 0.2,
    "max_tokens": 1024,
    "timeout": 45
  },

  "converter": {
    "robot_length": 0.281,
    "robot_width": 0.306,
    "safety_margin": 0.15
  },

  "semantic_map": {
    "path": "data/semantic_map.json",
    "auto_reload": true
  },

  "rgbd_topics": {
    "rgb": "/camera/rgb/image_raw",
    "depth": "/camera/depth/image_raw",
    "odom": "/odom",
    "camera_info": "/camera/rgb/camera_info"
  }
}
