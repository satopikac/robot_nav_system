{
  "profile": "real_robot",

  "runtime": {
    "mode": "ros_single",
    "use_ros": true,
    "auto_explore_on_startup": true,
    "resume_explore_after_task": true
  },

  "robots": {
    "names": ["robot"],
    "global_frame": "map",
    "base_frame_suffix": "base_link",
    "goal_timeout": 300.0,
    "server_timeout": 15.0,
    "default_positions": {
      "robot": [0.0, 0.0]
    }
  },

  "ros": {
    "move_base_action": "move_base",
    "frame_id": "map",
    "base_frame": "base_link"
  },

  "dmros": {
    "enabled": true,
    "output_dir": "output/semantic",
    "ros_stream_config": "config/dmros/real_robot.yaml",
    "poll_interval": 5.0,
    "use_llm_for_metadata": false
  },

  "exploration": {
    "enabled": true,
    "launch_file": "exploration/explore.launch",
    "planner_frequency": 0.5,
    "min_frontier_size": 0.5,
    "progress_timeout": 45.0
  },

  "llm": {
    "base_url": "https://api.deepseek.com",
    "api_key": "",
    "model": "deepseek-chat",
    "temperature": 0.2,
    "max_tokens": 1024,
    "timeout": 45
  },

  "converter": {
    "robot_length": 0.50,
    "robot_width": 0.40,
    "safety_margin": 0.20
  },

  "semantic_map": {
    "path": "data/semantic_map.json",
    "auto_reload": true
  },

  "rgbd_topics": {
    "rgb": "/camera/color/image_raw",
    "depth": "/camera/aligned_depth_to_color/image_raw",
    "odom": "/odom",
    "camera_info": "/camera/color/camera_info"
  }
}
