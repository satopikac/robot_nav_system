<launch>
  <!-- Gazebo world with TurtleBot3 house -->
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="waffle_pi recommended for RGBD"/>
  <arg name="num_robots" default="3"/>
  <arg name="world" default="$(find turtlebot3_gazebo)/worlds/turtlebot3_house.world"/>

  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world)"/>
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
  </include>

  <!-- Robot 0 -->
  <group ns="tb3_0">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" value="50.0"/>
      <param name="tf_prefix" value="tb3_0"/>
    </node>
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
          args="-urdf -model tb3_0 -x -7.0 -y -1.0 -z 0.0 -Y 1.57 -param robot_description"/>
  </group>

  <!-- Robot 1 -->
  <group if="$(eval arg('num_robots') >= 2)" ns="tb3_1">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" value="50.0"/>
      <param name="tf_prefix" value="tb3_1"/>
    </node>
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
          args="-urdf -model tb3_1 -x 7.0 -y -1.0 -z 0.0 -Y 1.57 -param robot_description"/>
  </group>

  <!-- Robot 2 -->
  <group if="$(eval arg('num_robots') >= 3)" ns="tb3_2">
    <param name="robot_description"
           command="$(find xacro)/xacro $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro"/>
    <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen">
      <param name="publish_frequency" value="50.0"/>
      <param name="tf_prefix" value="tb3_2"/>
    </node>
    <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf"
          args="-urdf -model tb3_2 -x 0.5 -y 3.0 -z 0.0 -Y 0.0 -param robot_description"/>
  </group>
</launch>
