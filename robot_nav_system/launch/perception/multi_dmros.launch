<launch>
  <!-- Multi-robot DMROS semantic mapping -->
  <!-- Each robot runs its own DMROS instance processing its own RGBD data -->
  <!-- Per-robot semantic maps are merged by MultiRobotMapManager in the orchestrator -->

  <arg name="dmros_config" default="$(find robot_nav_system)/config/dmros/turtlebot3_sim.yaml"/>
  <arg name="dmros_path" default=""/>

  <!-- DMROS instance for tb3_0 -->
  <node pkg="robot_nav_system" type="dmros_bridge_node.py"
        name="dmros_tb3_0" output="screen" ns="tb3_0">
    <param name="dmros_config" value="$(arg dmros_config)"/>
    <param name="robot_name" value="tb3_0"/>
    <param name="output_dir" value="output/tb3_0/semantic"/>
    <param name="rgb_topic" value="/tb3_0/camera/rgb/image_raw"/>
    <param name="depth_topic" value="/tb3_0/camera/depth/image_raw"/>
    <param name="odom_topic" value="/tb3_0/odom"/>
    <param name="camera_info_topic" value="/tb3_0/camera/rgb/camera_info"/>
  </node>

  <!-- DMROS instance for tb3_1 -->
  <node pkg="robot_nav_system" type="dmros_bridge_node.py"
        name="dmros_tb3_1" output="screen" ns="tb3_1">
    <param name="dmros_config" value="$(arg dmros_config)"/>
    <param name="robot_name" value="tb3_1"/>
    <param name="output_dir" value="output/tb3_1/semantic"/>
    <param name="rgb_topic" value="/tb3_1/camera/rgb/image_raw"/>
    <param name="depth_topic" value="/tb3_1/camera/depth/image_raw"/>
    <param name="odom_topic" value="/tb3_1/odom"/>
    <param name="camera_info_topic" value="/tb3_1/camera/rgb/camera_info"/>
  </node>

  <!-- DMROS instance for tb3_2 -->
  <node pkg="robot_nav_system" type="dmros_bridge_node.py"
        name="dmros_tb3_2" output="screen" ns="tb3_2">
    <param name="dmros_config" value="$(arg dmros_config)"/>
    <param name="robot_name" value="tb3_2"/>
    <param name="output_dir" value="output/tb3_2/semantic"/>
    <param name="rgb_topic" value="/tb3_2/camera/rgb/image_raw"/>
    <param name="depth_topic" value="/tb3_2/camera/depth/image_raw"/>
    <param name="odom_topic" value="/tb3_2/odom"/>
    <param name="camera_info_topic" value="/tb3_2/camera/rgb/camera_info"/>
  </node>
</launch>
